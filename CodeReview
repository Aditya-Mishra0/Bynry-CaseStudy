@app.route('/api/products', methods=['POST'])
def create_product():
# Checking if correct data 
    data = request.get_json(silent=True)
    if not data:
        return jsonify({"error": "No valid JSON payload provided"}), 400
# Validate required fields
    required = ['name', 'sku', 'price', 'warehouse_id', 'initial_quantity']
    if not all(field in data for field in required):
        return jsonify({"error": "Missing required fields"}), 400

    Try:
# Checking business logic and basic logic like price cannot be negative
        price = float(data['price'])
        quantity = int(data['initial_quantity'])
        warehouse_id = int(data['warehouse_id'])

        if price <= 0:
            return jsonify({"error": "Price must be greater than zero"}), 400
        if quantity < 0:
            return jsonify({"error": "Initial quantity cannot be negative"}), 400

        product = Product(
            name=data['name'].strip(),
            sku=data['sku'].strip().upper(),
            price=price,
            warehouse_id=warehouse_id
        )

        db.session.add(product)
        db.session.flush()

        inventory = Inventory(
            product_id=product.id,
            warehouse_id=warehouse_id,
            quantity=quantity
        )
        db.session.add(inventory)
#single commit in the very end 
        db.session.commit()
# returning message with message at http code
        return jsonify({
            "message": "Product created successfully",
            "product_id": product.id
        }), 201
 
#Exception handling in case of any error due to invalid or server issue
    except (ValueError, TypeError):
        db.session.rollback()
        return jsonify({"error": "Invalid data types or values"}), 400
    except IntegrityError:
        db.session.rollback()
        return jsonify({"error": "SKU already exists or invalid warehouse ID"}), 409
    except Exception:
        db.session.rollback()
        return jsonify({"error": "Internal server error"}), 500
